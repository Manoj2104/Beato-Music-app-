  "tracks": [
    {
      "id": "track-uploaded-1781170569476",
      "title": "Mutta Kalakki | Youth | Ken Karunaas ",
      "artistId": "user-1781170074483",
      "artistName": "Manoj S",
      "albumId": "album-uploads",
      "albumName": "Singles",
      "coverImage": "data:image/jpeg;base64,",
      "duration": 286,
      "audioUrl": "/uploads/audio/1781170569467-e8a9de15_227b_4bf2_860b_935e8c098445.mp3",
      "genre": "Pop",
      "year": 2026,
      "plays": 7,
      "liked": false,
      "explicit": false,
      "trackNumber": 1,
      "lyrics": "Ey manja balloon–u\r\nNee super saloon–u\r\nHey vaadi cooling watermelon–u…\r\nEn beauty buffoon–u\r\nHey body cologne–u\r\nHey unnala en life–u sukkunnu…\r\n\r\nNight aana kanavula vaaraadi–ye\r\nBright aana yosikiren unna pathiyae (Ae)\r\nMandaila padippu onnum erala–di\r\nAzhagula unna minja aal illadi (Ee)\r\n\r\nMinuki… nee dhaan\r\nEn nenja kuluki… siruki\r\nVaadi en muttakalakki… azhagi\r\nPovathae… romba vilagi… sinungi\r\nPorale enna muzhungi…\r\n\r\nLa–la–la… la–la–la…\r\nLa–la–la… la–la–la–la…\r\nLa–la–la… la–la–la…\r\nLa–la–la… la–la–la–la…\r\n\r\nInstrumental Break\r\n\r\nManasu full’ah un mela dhaan\r\nThirunthi pona unnala dhaan (Aiyyo)\r\nThiriyuren un pinnala dhaan (Oh ho…)\r\nOk solla kannala dhaan\r\n\r\nPuthusa porandha feeling–ma\r\nSiricha heart healing–ma\r\nKanaga love calling–ma\r\nEnna left hand–la dealing pannathama…\r\n\r\nInstrumental Break\r\n\r\nMinuki… nee dhaan\r\nEn nenja kuluki… siruki\r\nVaadi en muttakalakki… azhagi\r\nPovathae… romba vilagi… sinungi\r\nPorale enna muzhungi…\r\n\r\nMinukki… (Ah–ah–ah)\r\nSirukki… (Ah–ah–ah)\r\nAzhagi… (Ah–ah–ah)\r\nSinungi…\r\nPorale enna muzhungi…\r\n\r\nLa–la–la… la–la–la…\r\nLa–la–la… la–la–la–la…\r\nLa–la–la… la–la–la…\r\nLa–la–la… la–la–la–la…",
      "uploadedBy": "Manoj",
      "uploadedAt": "2026-06-11T09:36:09.477Z",
      "status": "approved"
    },
